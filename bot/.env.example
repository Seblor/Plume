# Copy this file to bot/.env and fill in the real values.
# Never commit bot/.env to version control.

NODE_ENV=production

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Discord webhook URL used by the bot to post internal logs
LOGS_WEBHOOK=

# URL prefix used to build log file preview links (leave trailing ?logfile=)
PREVIEW_PREFIX_URL=https://plume.red/viewer/v1?logfile=
